{
  "expo": {
    "name": "Staffly",
    "slug": "staffly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Staffly.png",
    "scheme": "staffly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Staffly.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.basthdev.staffly",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Staffly.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.basthdev.staffly"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/Staffly.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9d105859-60cd-4826-bebe-99f86d9539e5"
      }
    }
  }
}
